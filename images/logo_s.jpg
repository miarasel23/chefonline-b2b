function getRandStrArr($tpArr=array(),$bgKey=0){
	
	$returnStr = '';
	$numArr = count($tpArr);
	for($i=$bgKey+1;$i<$numArr;$i++){
		$returnStr .= $tpArr[$i].' ';
	}
	
	for($i=0;$i<=$bgKey;$i++){
		$returnStr .= $tpArr[$i].' ';
	}
	
	return trim($returnStr);

}


